    {
      "type": "text",
      "id": "json_evi_txt",
      "x": 121,
      "y": 1346,
      "width": 528,
      "height": 92,
      "text": "// one sub-count query (R1)\n{ \"$and\": [\n    < base security filter >,\n    { \"_id\": { \"$gte\": \"B1\", \"$lt\": \"B2\" } }\n] }",
      "originalText": "// one sub-count query (R1)\n{ \"$and\": [\n    < base security filter >,\n    { \"_id\": { \"$gte\": \"B1\", \"$lt\": \"B2\" } }\n] }",
      "fontSize": 14,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#22c55e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
