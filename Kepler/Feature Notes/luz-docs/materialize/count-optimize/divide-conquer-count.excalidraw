    {
      "type": "text",
      "id": "lim3_txt",
      "x": 917,
      "y": 1760,
      "width": 486,
      "height": 56,
      "text": "Speedup only if CPU-bound + spare cores + index resident.\nIf I/O-bound (cold pages), fan-out buys contention, not speed —\nrun explain() and check the cache hit ratio first.",
      "originalText": "Speedup only if CPU-bound + spare cores + index resident.\nIf I/O-bound (cold pages), fan-out buys contention, not speed —\nrun explain() and check the cache hit ratio first.",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "middle",
      "strokeColor": "#374151",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
