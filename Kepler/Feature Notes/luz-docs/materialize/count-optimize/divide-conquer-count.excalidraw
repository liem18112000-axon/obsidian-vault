    },
    {
      "type": "text",
      "id": "json_evi_note",
      "x": 700,
      "y": 1350,
      "width": 680,
      "height": 84,
      "text": "Plain 24-hex string bounds — the jsonstore gateway coerces _id → ObjectId,\nexactly as it already does for equality and $in lookups. No $oid extended JSON.\n\nFail-loud: any sub-count error throws → never a silent partial sum (a dropped\npartition would undercount = a security access-leak-shaped bug).",
      "originalText": "Plain 24-hex string bounds — the jsonstore gateway coerces _id → ObjectId,\nexactly as it already does for equality and $in lookups. No $oid extended JSON.\n\nFail-loud: any sub-count error throws → never a silent partial sum (a dropped\npartition would undercount = a security access-leak-shaped bug).",
      "fontSize": 14,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#64748b",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 300034,
      "version": 1,
      "versionNonce": 300035,
      "isDeleted": false,
      "groupIds": [],
      "boundElements": null,
      "link": null,
      "locked": false,
      "containerId": null,
      "lineHeight": 1.25
    },
