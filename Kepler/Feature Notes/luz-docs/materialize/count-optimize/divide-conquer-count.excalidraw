    {
      "type": "text",
      "id": "lim2_txt",
      "x": 917,
      "y": 1668,
      "width": 486,
      "height": 56,
      "text": "No secondary routing — the count REST client has no read-\npreference param. Aiming heavy sub-counts at an analytics\nsecondary needs a luz_jsonstore change.",
      "originalText": "No secondary routing — the count REST client has no read-\npreference param. Aiming heavy sub-counts at an analytics\nsecondary needs a luz_jsonstore change.",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "middle",
      "strokeColor": "#374151",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
