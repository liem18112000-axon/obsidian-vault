    {
      "type": "text",
      "id": "idx_evi_txt",
      "x": 121,
      "y": 1240,
      "width": 528,
      "height": 54,
      "text": "// indexes backing the ranged sub-count\n{ _effectiveSecurityClassCodes: 1,  _id: 1 }\n{ _isPublic: 1,  _id: 1 }",
      "originalText": "// indexes backing the ranged sub-count\n{ _effectiveSecurityClassCodes: 1,  _id: 1 }\n{ _isPublic: 1,  _id: 1 }",
      "fontSize": 14,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#22c55e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
