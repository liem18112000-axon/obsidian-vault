    {
      "type": "text",
      "id": "codemap_txt",
      "x": 80,
      "y": 1552,
      "width": 800,
      "height": 180,
      "text": "ENTRY   MaterializeFacade.countTotalDocumentByQuery()\n   └─ MaterializeRepository.countTotalDocumentByQuery()      delegates\n        └─ MaterializeCountFanout.count()                    submit K tasks → sum\n             └─ .partition()                                 base query ∧ each _id range\n                  └─ MongoDBUtil.objectIdRangeBounds(K)       → [ B1 … B(K-1) ]\n\nCONFIG  luz.docs.materialize.count-fanout-partitions    ( ≤ 1 = off, single count )",
      "originalText": "ENTRY   MaterializeFacade.countTotalDocumentByQuery()\n   └─ MaterializeRepository.countTotalDocumentByQuery()      delegates\n        └─ MaterializeCountFanout.count()                    submit K tasks → sum\n             └─ .partition()                                 base query ∧ each _id range\n                  └─ MongoDBUtil.objectIdRangeBounds(K)       → [ B1 … B(K-1) ]\n\nCONFIG  luz.docs.materialize.count-fanout-partitions    ( ≤ 1 = off, single count )",
      "fontSize": 14,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#374151",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 600003,
      "version": 1,
      "versionNonce": 600004,
      "isDeleted": false,
      "groupIds": [],
      "boundElements": null,
      "link": null,
      "locked": false,
      "containerId": null,
      "lineHeight": 1.4
    },
