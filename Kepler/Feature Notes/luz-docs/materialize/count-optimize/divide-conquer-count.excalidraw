    {
      "type": "text",
      "id": "idx_note",
      "x": 700,
      "y": 1226,
      "width": 690,
      "height": 84,
      "text": "_id as the SECOND index key lets Mongo bound each _id range INSIDE the\nmatched security-code interval → a sub-count walks only its own slice of\nindex entries, not a full re-scan.  Without _id in the index the range is\njust a post-filter (scan-all, discard) → K× the work, zero speedup.",
      "originalText": "_id as the SECOND index key lets Mongo bound each _id range INSIDE the\nmatched security-code interval → a sub-count walks only its own slice of\nindex entries, not a full re-scan.  Without _id in the index the range is\njust a post-filter (scan-all, discard) → K× the work, zero speedup.",
      "fontSize": 14,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#64748b",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 500007,
      "version": 1,
      "versionNonce": 500008,
      "isDeleted": false,
      "groupIds": [],
      "boundElements": null,
      "link": null,
      "locked": false,
      "containerId": null,
      "lineHeight": 1.25
    },
