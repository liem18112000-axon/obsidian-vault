    {
      "type": "text",
      "id": "lim1_txt",
      "x": 917,
      "y": 1560,
      "width": 486,
      "height": 72,
      "text": "Load skew — _id is timestamp-prefixed, so uniform hex cuts\nbucket unevenly by creation time. Sum stays EXACT; only balance\nsuffers. Swap quantile bounds into objectIdRangeBounds() to even it.",
      "originalText": "Load skew — _id is timestamp-prefixed, so uniform hex cuts\nbucket unevenly by creation time. Sum stays EXACT; only balance\nsuffers. Swap quantile bounds into objectIdRangeBounds() to even it.",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "middle",
      "strokeColor": "#374151",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 700005,
      "version": 1,
